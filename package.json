{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "server": "tsx server/index.ts",
    "start": "npm run server",
    "seed": "tsx server/seed-content.ts",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "dev:all": "concurrently \"npm run server\" \"npm run dev\"",
    "tunnel:frontend": "cloudflared.exe tunnel --url http://localhost:3000",
    "tunnel:backend": "cloudflared.exe tunnel --url http://localhost:3002",
    "tunnel:all": "concurrently \"npm run tunnel:frontend\" \"npm run tunnel:backend\"",
    "setup:tunnel": "curl -L https://github.com/cloudflare/cloudflared/releases/latest/download/cloudflared-windows-amd64.exe -o cloudflared.exe"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dompurify": "^3.3.3",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "html2pdf.js": "^0.14.0",
    "katex": "^0.16.38",
    "lucide-react": "^0.546.0",
    "marked": "^17.0.4",
    "motion": "^12.23.24",
    "multer": "^2.1.1",
    "pg": "^8.20.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/dompurify": "^3.0.5",
    "@types/express": "^4.17.21",
    "@types/marked": "^5.0.2",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.14.0",
    "@types/pg": "^8.18.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
